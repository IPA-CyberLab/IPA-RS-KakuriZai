+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::sync::Arc;
+    use vm_device::interrupt::{InterruptIndex, InterruptSourceConfig, Result};
+    use vmm_sys_util::eventfd::EventFd;
+
+    struct NoopInterruptSourceGroup;
+
+    impl InterruptSourceGroup for NoopInterruptSourceGroup {
+        fn trigger(&self, _index: InterruptIndex) -> Result<()> {
+            Ok(())
+        }
+
+        fn notifier(&self, _index: InterruptIndex) -> Option<EventFd> {
+            None
+        }
+
+        fn update(
+            &self,
+            _index: InterruptIndex,
+            _config: InterruptSourceConfig,
+            _masked: bool,
+        ) -> Result<()> {
+            Ok(())
+        }
+    }
+
+    fn new_msix_config(vectors: u16) -> MsixConfig {
+        MsixConfig::new(vectors, Arc::new(NoopInterruptSourceGroup), 0)
+    }
+
+    #[test]
+    fn out_of_range_table_access_does_not_panic() {
+        let mut config = new_msix_config(3);
+        let mut read = [0; 8];
+
+        config.read_table(3 * MSIX_TABLE_ENTRIES_MODULO, &mut read);
+        assert_eq!(read, [0xff; 8]);
+
+        let before = config.table_entries.clone();
+        config.write_table(3 * MSIX_TABLE_ENTRIES_MODULO, &[0; 8]);
+        assert_eq!(config.table_entries, before);
+    }
+
+    #[test]
+    fn out_of_range_pba_read_does_not_panic() {
+        let mut config = new_msix_config(64);
+        let mut read = [0; 8];
+
+        config.read_pba(2 * MSIX_PBA_ENTRIES_MODULO, &mut read);
+        assert_eq!(read, [0xff; 8]);
+    }
+}
