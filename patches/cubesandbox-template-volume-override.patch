+func mergeTemplateVolumes(volumes []*types.Volume, templateVolumes []*types.Volume) []*types.Volume {
+	if len(templateVolumes) == 0 {
+		return volumes
+	}
+	merged := append([]*types.Volume{}, volumes...)
+	byName := make(map[string]*types.Volume, len(merged))
+	for _, volume := range merged {
+		if volume == nil || volume.Name == "" {
+			continue
+		}
+		byName[volume.Name] = volume
+	}
+	for _, templateVolume := range templateVolumes {
+		if templateVolume == nil {
+			continue
+		}
+		if existing := byName[templateVolume.Name]; templateVolume.Name != "" && existing != nil {
+			applyTemplateVolumeDefaults(existing, templateVolume)
+			continue
+		}
+		merged = append(merged, templateVolume)
+	}
+	return merged
+}
+
+func applyTemplateVolumeDefaults(volume *types.Volume, templateVolume *types.Volume) {
+	if volume == nil || templateVolume == nil || templateVolume.VolumeSource == nil {
+		return
+	}
+	if volume.VolumeSource == nil {
+		volume.VolumeSource = templateVolume.VolumeSource
+		return
+	}
+	if volume.VolumeSource.EmptyDir != nil && templateVolume.VolumeSource.EmptyDir != nil {
+		if volume.VolumeSource.EmptyDir.SizeLimit == "" {
+			volume.VolumeSource.EmptyDir.SizeLimit = templateVolume.VolumeSource.EmptyDir.SizeLimit
+		}
+		if volume.VolumeSource.EmptyDir.Medium == 0 {
+			volume.VolumeSource.EmptyDir.Medium = templateVolume.VolumeSource.EmptyDir.Medium
+		}
+	}
+}
