+func TestApplyTemplateAnnotationsPreservesWritableLayerOverride(t *testing.T) {
+	templateReq := &types.CreateCubeSandboxReq{
+		Annotations: map[string]string{
+			constants.CubeAnnotationWritableLayerSize: "1G",
+			constants.CubeAnnotationsSystemDiskSize:   "1",
+		},
+	}
+	requestReq := &types.CreateCubeSandboxReq{
+		Annotations: map[string]string{
+			constants.CubeAnnotationWritableLayerSize: "10G",
+			constants.CubeAnnotationsSystemDiskSize:   "10",
+		},
+	}
+
+	applyTemplateAnnotationsAndLabels(templateReq, requestReq)
+
+	if got := requestReq.Annotations[constants.CubeAnnotationWritableLayerSize]; got != "10G" {
+		t.Fatalf("writable layer annotation=%q, want 10G", got)
+	}
+	if got := requestReq.Annotations[constants.CubeAnnotationsSystemDiskSize]; got != "10" {
+		t.Fatalf("system disk annotation=%q, want 10", got)
+	}
+}
