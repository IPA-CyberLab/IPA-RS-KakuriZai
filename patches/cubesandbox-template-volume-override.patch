+func TestMergeTemplateVolumesPrefersRequestRootfsSize(t *testing.T) {
+	requestVolumes := []*types.Volume{{
+		Name: "cube_rootfs_rw",
+		VolumeSource: &types.VolumeSource{
+			EmptyDir: &types.EmptyDirVolumeSource{SizeLimit: "10G"},
+		},
+	}}
+	templateVolumes := []*types.Volume{
+		{
+			Name: "cube_rootfs_rw",
+			VolumeSource: &types.VolumeSource{
+				EmptyDir: &types.EmptyDirVolumeSource{SizeLimit: "1G", Medium: 1},
+			},
+		},
+		{
+			Name: "template-cache",
+			VolumeSource: &types.VolumeSource{
+				EmptyDir: &types.EmptyDirVolumeSource{SizeLimit: "512Mi"},
+			},
+		},
+	}
+
+	got := mergeTemplateVolumes(requestVolumes, templateVolumes)
+
+	if len(got) != 2 {
+		t.Fatalf("len(got)=%d, want 2", len(got))
+	}
+	root := got[0].VolumeSource.EmptyDir
+	if root.SizeLimit != "10G" {
+		t.Fatalf("root SizeLimit=%q, want 10G", root.SizeLimit)
+	}
+	if root.Medium != 1 {
+		t.Fatalf("root Medium=%d, want template medium 1", root.Medium)
+	}
+	if got[1].Name != "template-cache" {
+		t.Fatalf("template volume was not appended: %q", got[1].Name)
+	}
+}
