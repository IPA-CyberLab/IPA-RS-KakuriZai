{
  "version": 1,
  "storeDir": ".kakurizai/store",
  "defaultBackend": "cube-sandbox-overlay",
  "studio": {
    "host": "127.0.0.1",
    "port": 38476
  },
  "auth": {
    "provider": "self",
    "issuer": "kakurizai",
    "audience": "kakurizai-studio",
    "secretFile": ".kakurizai/auth/self-secret"
  },
  "cube": {
    "mode": "auto",
    "cubecli": "cubecli",
    "mastercli": "cubemastercli",
    "apiBaseUrl": null,
    "template": "kakurizai-base",
    "namespace": "kakurizai",
    "cpu": "2000m",
    "memory": "2000Mi",
    "workspacePath": "/workspace"
  },
  "isolatedAgent": {
    "agentctl": "agentctl",
    "sourceTree": "vendor/IPA-RS-IsolatedAgent"
  }
}
