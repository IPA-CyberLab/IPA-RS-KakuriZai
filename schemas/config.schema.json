{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KakuriZai Config",
  "type": "object",
  "properties": {
    "version": { "const": 1 },
    "home": { "type": "string" },
    "storeDir": { "type": "string" },
    "defaultBackend": {
      "enum": [
        "apfs-clone",
        "windows-block-clone",
        "linux-native",
        "systemd-nspawn",
        "btrfs",
        "path-preserving-overlay",
        "windows-minifilter-overlay",
        "cube-sandbox-overlay"
      ]
    },
    "studio": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "publicUrl": { "type": ["string", "null"] },
        "secureCookies": { "type": "boolean" },
        "trustProxy": { "type": "boolean" },
        "trustedProxies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedHosts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trustedOrigins": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ipAllowlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ipDenylist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rateLimit": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "windowSeconds": { "type": "integer", "minimum": 1 },
            "maxRequests": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "tls": {
          "type": "object",
          "properties": {
            "certFile": { "type": ["string", "null"] },
            "keyFile": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "auth": {
      "oneOf": [
        {
          "type": "object",
          "required": ["provider"],
          "properties": {
            "provider": { "const": "none" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["provider", "users"],
          "properties": {
            "provider": { "const": "local" },
            "label": { "type": "string" },
            "users": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["passwordHash"],
                "properties": {
                  "passwordHash": { "type": "string" },
                  "disabled": { "type": "boolean" },
                  "displayName": { "type": "string" },
                  "roles": {
                    "oneOf": [
                      { "type": "string" },
                      { "type": "array", "items": { "type": "string" } }
                    ]
                  },
                  "permissions": {
                    "oneOf": [
                      { "type": "string" },
                      { "type": "array", "items": { "type": "string" } }
                    ]
                  },
                  "totpSecret": { "type": "string" },
                  "totp": {
                    "oneOf": [
                      { "type": "string" },
                      { "type": "object", "additionalProperties": true }
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "sessionTtlSeconds": { "type": "integer", "minimum": 60 },
            "maxLoginAttempts": { "type": "integer", "minimum": 1 },
            "persistSessions": { "type": "boolean" },
            "sessionFile": { "type": "string" },
            "rbac": { "type": "object", "additionalProperties": true },
            "totp": { "type": "object", "additionalProperties": true },
            "mfa": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["provider"],
          "properties": {
            "provider": { "const": "self" },
            "issuer": { "type": "string" },
            "audience": { "type": "string" },
            "secret": { "type": "string" },
            "secretFile": { "type": "string" },
            "sessionTtlSeconds": { "type": "integer", "minimum": 60 },
            "maxLoginAttempts": { "type": "integer", "minimum": 1 },
            "persistSessions": { "type": "boolean" },
            "sessionFile": { "type": "string" },
            "rbac": { "type": "object", "additionalProperties": true },
            "totp": { "type": "object", "additionalProperties": true },
            "mfa": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["provider", "domain", "audience"],
          "properties": {
            "provider": { "const": "auth0" },
            "domain": { "type": "string" },
            "audience": { "type": "string" },
            "issuer": { "type": "string" },
            "jwksUri": { "type": "string" },
            "sessionTtlSeconds": { "type": "integer", "minimum": 60 },
            "maxLoginAttempts": { "type": "integer", "minimum": 1 },
            "persistSessions": { "type": "boolean" },
            "sessionFile": { "type": "string" },
            "rbac": { "type": "object", "additionalProperties": true },
            "totp": { "type": "object", "additionalProperties": true },
            "mfa": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["provider", "region", "userPoolId"],
          "properties": {
            "provider": { "const": "cognito" },
            "region": { "type": "string" },
            "userPoolId": { "type": "string" },
            "clientId": { "type": "string" },
            "audience": { "type": "string" },
            "issuer": { "type": "string" },
            "jwksUri": { "type": "string" },
            "sessionTtlSeconds": { "type": "integer", "minimum": 60 },
            "maxLoginAttempts": { "type": "integer", "minimum": 1 },
            "persistSessions": { "type": "boolean" },
            "sessionFile": { "type": "string" },
            "rbac": { "type": "object", "additionalProperties": true },
            "totp": { "type": "object", "additionalProperties": true },
            "mfa": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["provider", "issuer", "jwksUri"],
          "properties": {
            "provider": { "const": "oidc" },
            "issuer": { "type": "string" },
            "audience": { "type": "string" },
            "jwksUri": { "type": "string" },
            "sessionTtlSeconds": { "type": "integer", "minimum": 60 },
            "maxLoginAttempts": { "type": "integer", "minimum": 1 },
            "persistSessions": { "type": "boolean" },
            "sessionFile": { "type": "string" },
            "rbac": { "type": "object", "additionalProperties": true },
            "totp": { "type": "object", "additionalProperties": true },
            "mfa": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        }
      ]
    },
    "audit": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "logReads": { "type": "boolean" },
        "file": { "type": "string" },
        "chain": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "security": {
      "type": "object",
      "properties": {
        "enforceRemoteAccess": { "type": "boolean" },
        "allowInsecureRemote": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "observability": {
      "type": "object",
      "properties": {
        "retentionSamples": { "type": "integer", "minimum": 1 },
        "traceEvents": { "type": "integer", "minimum": 1 },
        "tracing": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "cube": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["auto", "master", "cli", "api", "disabled"] },
        "cubecli": { "type": "string" },
        "mastercli": { "type": "string" },
        "apiBaseUrl": { "type": ["string", "null"] },
        "template": { "type": "string" },
        "namespace": { "type": "string" },
        "cpu": { "type": "string" },
        "memory": { "type": "string" },
        "workspacePath": { "type": "string" }
      },
      "additionalProperties": true
    },
    "isolatedAgent": {
      "type": "object",
      "properties": {
        "agentctl": { "type": "string" },
        "sourceTree": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
