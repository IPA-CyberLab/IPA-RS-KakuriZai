{
  "name": "ipa-rs-kakurizai",
  "version": "0.1.0",
  "description": "Sandbox lifecycle control plane and Studio UI backed by the CubeSandbox runtime.",
  "type": "module",
  "bin": {
    "agctl": "./dist/bin/agctl.js"
  },
  "scripts": {
    "agctl": "npm run build --silent && node ./dist/bin/agctl.js",
    "build": "tsc -p tsconfig.json && vite build && chmod +x dist/bin/agctl.js",
    "start": "npm run build --silent && node ./dist/bin/agctl.js studio",
    "test": "npm run build --silent && node --test",
    "test:responsive": "playwright test --config playwright.config.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.562.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
